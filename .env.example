# ============================================================================
# SCRAPEE MCP SERVER - ENVIRONMENT VARIABLES
# ============================================================================

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=8080

# Frontend URLs (CORS)
FRONTEND_URL=http://localhost:3000
VERCEL_URL=

# ============================================================================
# REDIS CONFIGURATION (Required for Production)
# ============================================================================
# For Vercel + Upstash Redis, get your Redis URL from:
# https://console.upstash.com/

# Option 1: Use REDIS_URL (Recommended for Upstash)
REDIS_URL=redis://default:your-password@your-endpoint.upstash.io:6379

# Option 2: Use individual connection parameters
# REDIS_HOST=your-endpoint.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. Create a free Upstash Redis account:
#    https://console.upstash.com/
#
# 2. Create a new Redis database
#
# 3. Copy the "REDIS_URL" from the dashboard
#
# 4. Paste it above (or use individual parameters)
#
# 5. For Vercel deployment, add these as environment variables:
#    Settings → Environment Variables → Add REDIS_URL
#
# 6. Without Redis, the MCP server will use in-memory storage 
#    (data lost on cold starts)
#
# ============================================================================
